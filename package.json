{
  "name": "inventory-api",
  "version": "1.0.0",
  "description": "A REST API for inventory management, built as a backend portfolio project.",
  "main": "dist/server.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --singleThreaded",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit --singleThreaded",
    "test": "vitest run src",
    "test:watch": "vitest src",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:check": "tsx src/scripts/check-database.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CarlosGit0519/inventory-api.git"
  },
  "keywords": [],
  "author": "Carlos",
  "license": "ISC",
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "type": "module",
  "bugs": {
    "url": "https://github.com/CarlosGit0519/inventory-api/issues"
  },
  "homepage": "https://github.com/CarlosGit0519/inventory-api#readme",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
